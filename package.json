{
  "name": "enterprise-admin-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A modern enterprise-level admin starter based on Vue3 + TypeScript.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:mock-server": "node mock-server/index.js",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@unocss/reset": "^0.65.4",
    "axios": "^1.7.9",
    "echarts": "^5.6.0",
    "element-plus": "^2.9.2",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "mockjs": "^1.1.0",
    "monaco-editor": "^0.52.2",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.5",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/mockjs": "^1.0.10",
    "@types/node": "^22.10.5",
    "@tsconfig/node22": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "typescript": "~5.7.2",
    "unocss": "^0.65.4",
    "vite": "^6.0.6",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  },
  "lint-staged": {
    "*.{ts,vue,js,json,css,md}": [
      "prettier --write"
    ],
    "*.{ts,vue,js}": [
      "eslint --fix"
    ]
  }
}
